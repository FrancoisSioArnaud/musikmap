query_for_run() {
  # run_index est 1-based
  local username="$1"
  local run_index="$2"
  local q
  q="$(queries_for_user "$username" | sed -n "${run_index}p" || true)"
  echo "${q:-}"
}

# =========================
# Login session per user (one time)
# =========================

login_user() {
  local username="$1"
  local jar="$ROOT_DIR/.seed_cookies_${username}.txt"
  rm -f "$jar"

  http_get_seed_csrf "$jar"
  local csrf
  csrf="$(py_extract_cookie_value "$jar" "csrftoken")"
  [[ -n "${csrf:-}" ]] || { echo "ERROR: [$username] csrftoken introuvable (seed)" >&2; dump_cookiejar "$jar"; exit 1; }

  http_get_login_page "$jar" || true
  http_post_login "$jar" "$username" "$csrf"

  local sessionid
  sessionid="$(py_extract_cookie_value "$jar" "sessionid")"
  [[ -n "${sessionid:-}" ]] || { echo "ERROR: [$username] sessionid absent après login" >&2; dump_cookiejar "$jar"; exit 1; }

  # Refresh csrf après login
  http_get_seed_csrf "$jar"
  csrf="$(py_extract_cookie_value "$jar" "csrftoken")"
  [[ -n "${csrf:-}" ]] || { echo "ERROR: [$username] csrftoken introuvable après login" >&2; dump_cookiejar "$jar"; exit 1; }

  echo "$jar|$csrf"
}

# =========================
# Deposit 1 song for one user for a given run
# =========================

deposit_one_for_run() {
  local username="$1"
  local jar="$2"
  local csrf="$3"
  local run_index="$4"

  local q
  q="$(query_for_run "$username" "$run_index")"
  if [[ -z "${q:-}" ]]; then
    echo "     WARN: [$username] pas de query pour run=$run_index (skip)" >&2
    return 0
  fi

  local body="$ROOT_DIR/.seed_tmp_${username}_r${run_index}_search_body.json"
  local hdr="$ROOT_DIR/.seed_tmp_${username}_r${run_index}_search_hdr.txt"
  local stf="$ROOT_DIR/.seed_tmp_${username}_r${run_index}_search_status.txt"

  http_post_spotify_search_capture "$jar" "$csrf" "$q" "$body" "$hdr" "$stf"

  local status ctype
  status="$(cat "$stf" 2>/dev/null || true)"
  ctype="$(header_get "$hdr" "Content-Type" || true)"

  if [[ "${status:-}" != "200" ]]; then
    echo "     WARN: [$username] spotify/search HTTP $status (skip) q='$q'" >&2
    return 0
  fi
  if [[ "${ctype:-}" != *"application/json"* ]]; then
    echo "     WARN: [$username] spotify/search pas JSON (Content-Type=${ctype:-unknown}) (skip) q='$q'" >&2
    return 0
  fi

  local option_json
  option_json="$(py_extract_first_track_option_from_file "$body")"
  if [[ -z "${option_json:-}" ]]; then
    echo "     WARN: [$username] search OK mais aucun résultat (skip) q='$q'" >&2
    return 0
  fi

  http_post_deposit_from_option_json "$jar" "$csrf" "$option_json"
  echo "     OK: [$username] run=$run_index déposée via q='$q'"
}

# =========================
# Main
# =========================

main() {
  need_cmd curl
  need_cmd python3

  cd "$ROOT_DIR"
  [[ -f "$ROOT_DIR/manage.py" ]] || { echo "ERROR: manage.py introuvable: $ROOT_DIR/manage.py" >&2; exit 1; }

  create_users_in_db

  local users=(
    emma.orbit
    hugo.wave
    karim.groove
    lea.moon
    lucas.verso
    max.jazzy
    nina.silk
    sara.aurora
    theo.noir
    zoe.vapor
  )

  # 1) Login une fois par user (on réutilise jar + csrf)
  declare -A JAR_BY_USER
  declare -A CSRF_BY_USER

  echo "==> Login des users (1 fois)"
  for u in "${users[@]}"; do
    echo "   - [$u] login"
    IFS='|' read -r jar csrf < <(login_user "$u")
    JAR_BY_USER["$u"]="$jar"
    CSRF_BY_USER["$u"]="$csrf"
  done

  # 2) RUNS itérations : à chaque run, chaque user dépose 1 chanson
  echo "==> Dépôts: ${RUNS} runs (chaque run = 1 dépôt par user)"
  local r
  for ((r=START_RUN; r<=RUNS; r++)); do
    echo "==> RUN $r/$RUNS"
    for u in "${users[@]}"; do
      deposit_one_for_run "$u" "${JAR_BY_USER[$u]}" "${CSRF_BY_USER[$u]}" "$r"
      sleep 0.15
    done
  done

  echo "==> Terminé."
}

main "$@"
