#!/usr/bin/env bash
set -euo pipefail

# =========================
# Config
# =========================
BASE_URL="${BASE_URL:-https://musikmap.com}"
BOX_SLUG="${BOX_SLUG:-chantier-naval}"
PASSWORD="${PASSWORD:-test1234}"

# Nombre de “runs” (itérations) : à chaque run, chaque user dépose 1 chanson.
RUNS="${RUNS:-10}"
START_RUN="${START_RUN:-1}"   # 1..RUNS (utile si tu veux reprendre à 5 par ex)

LOGIN_PAGE="$BASE_URL/users/login/"
LOGIN_POST="$BASE_URL/users/login/"
CSRF_SEED_URL="${CSRF_SEED_URL:-$BASE_URL/admin/login/}"

SPOTIFY_SEARCH="$BASE_URL/spotify/search"
DEPOSIT_POST="$BASE_URL/box-management/get-box/"

SPOTIFY_REFERER="${SPOTIFY_REFERER:-$BASE_URL/flowbox/$BOX_SLUG/search}"
ORIGIN="$BASE_URL"

UA="seed_demo_musikmap/1.6 (+curl)"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# =========================
# Helpers
# =========================

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "ERROR: commande manquante: $1" >&2; exit 1; }
}

dump_cookiejar() {
  local jar="$1"
  echo "---- cookiejar: $jar ----"
  sed -n '1,220p' "$jar" || true
  echo "--------------------------"
}

py_extract_cookie_value() {
  # IMPORTANT: gère les lignes "#HttpOnly_..." (format curl)
  local path="$1"
  local cookie_name="$2"
  python3 - "$path" "$cookie_name" <<'PY'
import sys
path = sys.argv[1]
name_wanted = sys.argv[2]
val = ""
with open(path, "r", encoding="utf-8", errors="ignore") as f:
    for line in f:
        line = line.rstrip("\n")
        if not line.strip():
            continue
        if line.startswith("#HttpOnly_"):
            line = line[len("#HttpOnly_"):]
        elif line.startswith("#"):
            continue
        parts = line.split("\t")
        if len(parts) >= 7 and parts[5] == name_wanted:
            val = parts[6]
print(val)
PY
}

py_extract_first_track_option_from_file() {
  # Lit un fichier JSON de /spotify/search et renvoie un JSON "option" (ou vide si rien)
  local body_file="$1"
  python3 - "$body_file" <<'PY'
import sys, json
path = sys.argv[1]
raw = open(path, "r", encoding="utf-8", errors="ignore").read().strip()
if not raw:
    print("")
    sys.exit(0)

try:
    data = json.loads(raw)
except Exception:
    print("")
    sys.exit(0)

items = None
if isinstance(data, list):
    items = data
elif isinstance(data, dict):
    for k in ("results", "items", "data"):
        v = data.get(k)
        if isinstance(v, list):
            items = v
            break

if not items or not isinstance(items, list):
    print("")
    sys.exit(0)

x = items[0]
if not isinstance(x, dict):
    print("")
    sys.exit(0)

opt = {
  "id": x.get("id"),
  "name": x.get("name"),
  "artist": x.get("artist"),
  "album": x.get("album"),
  "image_url": x.get("image_url"),
  "duration": x.get("duration"),
  "platform_id": x.get("platform_id"),
  "url": x.get("url"),
}

if not opt.get("name") or not opt.get("artist"):
    print("")
    sys.exit(0)

print(json.dumps(opt, ensure_ascii=False))
PY
}

header_get() {
  local hdr="$1"
  local key="$2"
  awk -v IGNORECASE=1 -v k="$key" '
    BEGIN{FS=":"}
    $1 ~ ("^" k "$") { sub(/^[^:]*:[ \t]*/, "", $0); gsub(/\r/,"",$0); print $0; exit }
  ' "$hdr"
}

http_get_seed_csrf() {
  local jar="$1"
  curl -sS --compressed \
    -A "$UA" \
    -c "$jar" -b "$jar" \
    "$CSRF_SEED_URL" >/dev/null
}

http_get_login_page() {
  local jar="$1"
  curl -sS --compressed \
    -A "$UA" \
    -c "$jar" -b "$jar" \
    "$LOGIN_PAGE" >/dev/null
}

http_post_login() {
  local jar="$1"
  local username="$2"
  local csrf="$3"

  curl -sS -L --compressed \
    -A "$UA" \
    -c "$jar" -b "$jar" \
    -H "Referer: $LOGIN_PAGE" \
    -H "Origin: $ORIGIN" \
    -H "X-CSRFToken: $csrf" \
    --data-urlencode "csrfmiddlewaretoken=$csrf" \
    --data-urlencode "username=$username" \
    --data-urlencode "password=$PASSWORD" \
    "$LOGIN_POST" >/dev/null
}

http_post_spotify_search_capture() {
  local jar="$1"
  local csrf="$2"
  local q="$3"
  local out_body="$4"
  local out_hdr="$5"
  local out_status="$6"

  rm -f "$out_body" "$out_hdr" "$out_status"

  local status
  status="$(
    curl -sS --compressed \
      -A "$UA" \
      -c "$jar" -b "$jar" \
      -D "$out_hdr" \
      -o "$out_body" \
      -w "%{http_code}" \
      -H "Accept: */*" \
      -H "Content-Type: application/json" \
      -H "Origin: $ORIGIN" \
      -H "Referer: $SPOTIFY_REFERER" \
      -H "X-CSRFToken: $csrf" \
      --data "{\"search_query\": \"${q//\"/\\\"}\"}" \
      "$SPOTIFY_SEARCH"
  )"
  printf "%s" "$status" > "$out_status"
}

http_post_deposit_from_option_json() {
  local jar="$1"
  local csrf="$2"
  local option_json="$3"

  python3 - <<PY | curl -sS --compressed \
    -A "$UA" \
    -c "$jar" -b "$jar" \
    -H "Accept: application/json" \
    -H "Content-Type: application/json" \
    -H "Origin: $ORIGIN" \
    -H "Referer: $BASE_URL/" \
    -H "X-CSRFToken: $csrf" \
    --data @- \
    "$DEPOSIT_POST" >/dev/null
import json
opt = json.loads('''$option_json''')
payload = {"option": opt, "boxSlug": "$BOX_SLUG"}
print(json.dumps(payload, ensure_ascii=False))
PY
}

