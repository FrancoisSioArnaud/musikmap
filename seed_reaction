#!/usr/bin/env python3
import os
import sys
import random
import argparse

# ------------------------------------------------------------
# Django bootstrap
# ------------------------------------------------------------
PROJECT_SETTINGS = "la_boite_a_son.settings"

os.environ.setdefault("DJANGO_SETTINGS_MODULE", PROJECT_SETTINGS)

try:
    import django  # noqa
except ImportError:
    print("ERROR: Django n'est pas importable. Active ton venv et réessaie.", file=sys.stderr)
    sys.exit(1)

django.setup()

from django.db import transaction  # noqa: E402
from django.contrib.auth import get_user_model  # noqa: E402

from box_management.models import Deposit, Emoji, EmojiRight, Reaction  # noqa: E402


def pick_unique_deposits_for_user(user, deposits_qs, n: int):
    """
    Retourne une liste de dépôts (instances) sur lesquels l'user n'a pas encore réagi.
    On essaie d'éviter ses propres dépôts si possible.
    """
    # Dépôts déjà réagis par ce user
    already = set(
        Reaction.objects.filter(user=user).values_list("deposit_id", flat=True)
    )

    # 1) on tente d'abord sans les dépôts du user
    candidates = list(
        deposits_qs.exclude(user=user).exclude(id__in=already).values_list("id", flat=True)
    )

    # Si pas assez, on autorise aussi ses dépôts
    if len(candidates) < n:
        more = list(
            deposits_qs.exclude(id__in=already).values_list("id", flat=True)
        )
        # union en gardant unique
        s = set(candidates)
        for did in more:
            if did not in s:
                candidates.append(did)
                s.add(did)

    if not candidates:
        return []

    # sample sans dépasser
    k = min(n, len(candidates))
    chosen_ids = random.sample(candidates, k=k)
    # on refetch les instances (prévisible)
    dep_by_id = {d.id: d for d in Deposit.objects.filter(id__in=chosen_ids)}
    return [dep_by_id[i] for i in chosen_ids if i in dep_by_id]


def pick_random_emoji_for_user(user, active_emojis):
    """
    Choisit un emoji aléatoire.
    Si cost > 0, on s'assure que l'user a un EmojiRight (créé si besoin).
    """
    emoji = random.choice(active_emojis)

    if (emoji.cost or 0) > 0:
        EmojiRight.objects.get_or_create(user=user, emoji=emoji)

    return emoji


def main():
    parser = argparse.ArgumentParser(
        description="Seed random reactions: N reactions per user, random deposits, random emojis."
    )
    parser.add_argument("--per-user", type=int, default=10, help="Nombre de réactions à créer par user (défaut: 10)")
    parser.add_argument("--seed", type=int, default=None, help="Seed RNG (pour reproductibilité)")
    parser.add_argument("--include-staff", action="store_true", help="Inclure les staff/superusers (défaut: non)")
    parser.add_argument("--limit-users", type=int, default=None, help="Limiter à N users (au hasard)")

    args = parser.parse_args()

    if args.seed is not None:
        random.seed(args.seed)

    User = get_user_model()

    users_qs = User.objects.all()
    if not args.include_staff:
        # évite superusers/staff par défaut
        users_qs = users_qs.filter(is_staff=False, is_superuser=False)

    users = list(users_qs)
    if not users:
        print("Aucun utilisateur trouvé (ou filtré).")
        return 0

    if args.limit_users is not None and args.limit_users > 0:
        if len(users) > args.limit_users:
            users = random.sample(users, k=args.limit_users)

    deposits_qs = Deposit.objects.all()
    deposits_count = deposits_qs.count()
    if deposits_count == 0:
        print("Aucun dépôt en base. Impossible de créer des réactions.")
        return 1

    active_emojis = list(Emoji.objects.filter(active=True))
    if not active_emojis:
        print("Aucun emoji actif en base. Crée des Emoji d'abord.")
        return 1

    created = 0
    updated = 0
    skipped = 0

    # Transaction globale (tu peux enlever si tu veux que ça passe user par user)
    with transaction.atomic():
        for u in users:
            targets = pick_unique_deposits_for_user(u, deposits_qs, args.per_user)
            if not targets:
                print(f"- {u.username}: aucun dépôt disponible (déjà réagis partout ?)")
                continue

            for dep in targets:
                emoji = pick_random_emoji_for_user(u, active_emojis)

                obj, was_created = Reaction.objects.get_or_create(
                    user=u,
                    deposit=dep,
                    defaults={"emoji": emoji},
                )
                if was_created:
                    created += 1
                else:
                    # déjà une réaction sur ce dépôt => on change l'emoji aléatoirement
                    if obj.emoji_id != emoji.id:
                        obj.emoji = emoji
                        obj.save(update_fields=["emoji", "updated_at"])
                        updated += 1
                    else:
                        skipped += 1

            print(f"- {u.username}: {len(targets)} réactions traitées")

    print("")
    print("Résumé:")
    print(f"  created: {created}")
    print(f"  updated: {updated}")
    print(f"  skipped (déjà même emoji): {skipped}")
    print(f"  users: {len(users)}")
    print(f"  deposits_total: {deposits_count}")
    print(f"  emojis_actifs: {len(active_emojis)}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
